   /devices/import:
     post:
       summary: Import devices via CSV file
       tags:
         - devices
       description: |-
         Import devices from a CSV file. The file should contain device tokens, platforms, and optional user IDs and tags.
         Example CSV format:
         ```
         device_token,platform,user_id,tags
         token1,ios,user1,tag1
         token2,android,user2,"tag2,tag3"
         ```
       responses:
         '204':
           description: No Content
         '401':
           description: Unauthorized
           content:
             application/json:
               schema:
                 description: Unauthorized
                 type: object
                 properties:
                   message:
                     type: string
                     description: Error message indicating the request is unauthorized
   /notifications:
     get:
       summary: Get list of notifications
       tags:
         - notifications
       parameters:
         - schema:
             type: integer
             minimum: 1
             maximum: 100
             default: 40
           in: query
           name: limit
           required: false
           description: Maximum number of items to return
         - schema:
             type: integer
             minimum: 0
             default: 0
           in: query
           name: offset
           required: false
           description: Number of items to skip before starting to collect the result set
         - schema:
             type: string
             pattern: ^[a-fA-F0-9]{24}$
           in: query
           name: campaign_id
           required: false
           description: Filter notifications by campaign ID
         - schema:
             type: string
             enum:
               - new
               - sent
               - failed
               - delivered
               - undelivered
           in: query
           name: status
           required: false
           description: Filter notifications by status
         - schema:
             type: string
             pattern: ^[a-fA-F0-9]{24}$
           in: query
           name: device_id
           required: false
           description: Filter notifications by device ID
       responses:
         '200':
           description: Paginated list of notifications
           content:
             application/json:
               schema:
                 description: Paginated list of notifications
                 type: object
                 properties:
                   total:
                     type: integer
                     description: Total number of notifications
                   limit:
                     type: integer
                     description: Number of notifications returned
                   offset:
                     type: integer
                     description: Offset for pagination
                   items:
                     type: array
                     items:
                       type: object
                       properties:
                         _id:
                           type: string
                           pattern: ^[a-fA-F0-9]{24}$
                           description: Unique identifier for the notification
                         device_id:
                           type: string
                           pattern: ^[a-fA-F0-9]{24}$
                           description: Identifier of the device to which the notification was sent
                         campaign_id:
                           type: string
                           pattern: ^[a-fA-F0-9]{24}$
                           description: Identifier of the campaign associated with the notification
                         title:
                           type: string
                           description: Title of the notification
                         body:
                           type: string
                           description: Body text of the notification
                         click_url:
                           type: string
                           format: uri
                           description: URL to open when the notification is clicked
                         status:
                           type: string
                           enum:
                             - new
                             - sent
                             - failed
                             - delivered
                             - undelivered
                           description: Status of the notification
                         attempt:
                           type: integer
                           minimum: 0
                           maximum: 5
                           default: 0
                           description: Number of attempts made to send the notification
                         next_attempt:
                           type: string
                           format: date-time
                           description: Timestamp for the next attempt to send the notification
                         created_at:
                           type: string
                           format: date-time
                           description: Creation timestamp
                         updated_at:
                           type: string
                           format: date-time
                           description: Last update timestamp
                       required:
                         - _id
                         - device_id
                         - campaign_id
                         - title
                         - body
                         - status
                     description: List of notifications
         '400':
           description: Bad Request
           content:
             application/json:
               schema:
                 description: Bad Request
                 type: object
                 properties:
                   message:
                     type: string
                     description: Error message indicating the request was invalid
                   errors:
                     type: array
                     items:
                       type: object
                       required:
                         - field
                         - message
                       properties:
                         field:
                           type: string
                           description: The field that caused the error
                         message:
                           type: string
                           description: Error message for the field
         '401':
           description: Unauthorized
           content:
             application/json:
               schema:
                 description: Unauthorized
                 type: object
                 properties:
                   message:
                     type: string
                     description: Error message indicating the request is unauthorized
